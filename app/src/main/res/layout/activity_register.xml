<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@id/screenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    android:orientation="vertical"
    tools:context=".RegisterActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout style="@style/ScreenBody">
            <TextView
                android:id="@id/backButton"
                style="@style/LinkText"
                android:text="‹ Retour" />

            <TextView
                style="@style/AppTitle"
                android:layout_marginTop="14dp"
                android:text="Créer un compte" />

            <TextView
                style="@style/AppSubtitle"
                android:text="Rejoignez CV Builder" />

            <TextView
                style="@style/LabelText"
                android:layout_marginTop="18dp"
                android:text="Prénom" />

            <EditText
                style="@style/AppField"
                android:hint="Entrez votre prénom" />

            <TextView
                style="@style/LabelText"
                android:text="Nom" />

            <EditText
                style="@style/AppField"
                android:hint="Entrez votre nom" />

            <TextView
                style="@style/LabelText"
                android:text="Email" />

            <EditText
                style="@style/AppField"
                android:hint="Entrez votre email"
                android:inputType="textEmailAddress" />

            <TextView
                style="@style/LabelText"
                android:text="Mot de passe" />

            <EditText
                style="@style/AppField"
                android:hint="Créez un mot de passe"
                android:inputType="textPassword" />

            <TextView
                style="@style/MutedText"
                android:layout_marginBottom="16dp"
                android:text="J'accepte les Conditions d'utilisation et la Politique de confidentialité" />

            <Button
                android:id="@id/registerButton"
                style="@style/AppButtonPrimary"
                android:text="S'inscrire" />

            <TextView
                android:id="@id/loginLink"
                style="@style/MutedText"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:text="Déjà un compte ? Se connecter" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
