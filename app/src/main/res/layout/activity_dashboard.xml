<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@id/screenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    android:orientation="vertical"
    tools:context=".DashboardActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout style="@style/ScreenBody">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/AppTitle"
                        android:text="Bonjour Camille" />

                    <TextView
                        style="@style/AppSubtitle"
                        android:text="Que souhaitez-vous faire aujourd'hui ?" />
                </LinearLayout>

                <TextView
                    android:id="@id/notificationsButton"
                    style="@style/LinkText"
                    android:gravity="center"
                    android:text="!" />
            </LinearLayout>

            <LinearLayout
                android:id="@id/createCvCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_hero"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/AppTitle"
                        android:text="Créer un nouveau CV"
                        android:textColor="@color/white"
                        android:textSize="17sp" />

                    <TextView
                        style="@style/AppSubtitle"
                        android:text="Commencez un CV à partir de zéro"
                        android:textColor="@color/splash_subtitle" />
                </LinearLayout>

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/splash_blue"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <include layout="@layout/row_dashboard_items" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/include_bottom_nav" />
</LinearLayout>
