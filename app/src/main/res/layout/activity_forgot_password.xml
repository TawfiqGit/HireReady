<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@id/screenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    android:orientation="vertical"
    tools:context=".ForgotPasswordActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout style="@style/ScreenBody">
            <TextView
                android:id="@id/backButton"
                style="@style/LinkText"
                android:text="‹ Retour" />

            <TextView
                style="@style/AppTitle"
                android:layout_marginTop="18dp"
                android:text="Mot de passe oublié" />

            <TextView
                style="@style/AppSubtitle"
                android:text="Entrez votre email et nous vous enverrons un lien pour réinitialiser votre mot de passe." />

            <TextView
                style="@style/LabelText"
                android:layout_marginTop="24dp"
                android:text="Email" />

            <EditText
                style="@style/AppField"
                android:hint="Entrez votre email"
                android:inputType="textEmailAddress" />

            <Button
                android:id="@id/sendLinkButton"
                style="@style/AppButtonPrimary"
                android:text="Envoyer le lien" />

            <TextView
                android:id="@id/loginLink"
                style="@style/LinkText"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:text="Retour à la connexion" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
