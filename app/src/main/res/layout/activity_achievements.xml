<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@id/screenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    android:orientation="vertical"
    tools:context=".AchievementsActivity">

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout style="@style/ScreenBody">
            <TextView android:id="@id/backButton" style="@style/LinkText" android:text="‹ Retour" />
            <TextView style="@style/AppTitle" android:layout_marginTop="16dp" android:text="Réalisations" />
            <TextView style="@style/AppSubtitle" android:text="Mettez en avant vos réalisations." />

            <TextView style="@style/CardRow" android:layout_marginTop="20dp" android:text="Réduction du turnover de 15% en 2 ans.        ›" android:textColor="@color/app_ink" android:textStyle="bold" />
            <TextView style="@style/CardRow" android:text="Mise en place d'un processus de recrutement agile.        ›" android:textColor="@color/app_ink" android:textStyle="bold" />
            <TextView style="@style/CardRow" android:text="Accompagnement de plus de 200 collaborateurs.        ›" android:textColor="@color/app_ink" android:textStyle="bold" />

            <TextView style="@style/LinkText" android:layout_gravity="center_horizontal" android:layout_marginTop="8dp" android:text="+ Ajouter une réalisation" />
            <include layout="@layout/include_form_actions" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
