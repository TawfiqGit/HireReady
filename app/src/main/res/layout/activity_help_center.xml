<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@id/screenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    android:orientation="vertical"
    tools:context=".HelpCenterActivity">

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout style="@style/ScreenBody">
            <TextView android:id="@id/backButton" style="@style/LinkText" android:text="‹ Retour" />
            <TextView style="@style/AppTitle" android:layout_marginTop="16dp" android:text="Centre d'aide" />
            <EditText style="@style/AppField" android:layout_marginTop="18dp" android:hint="Rechercher une aide" />
            <TextView style="@style/CardRow" android:text="Créer un CV        ›" android:textColor="@color/app_ink" android:textStyle="bold" />
            <TextView style="@style/CardRow" android:text="Modifier un CV        ›" android:textColor="@color/app_ink" android:textStyle="bold" />
            <TextView style="@style/CardRow" android:text="Exporter un CV        ›" android:textColor="@color/app_ink" android:textStyle="bold" />
            <TextView style="@style/CardRow" android:text="Compte et abonnement        ›" android:textColor="@color/app_ink" android:textStyle="bold" />
            <TextView style="@style/CardRow" android:text="Résoudre un problème        ›" android:textColor="@color/app_ink" android:textStyle="bold" />
            <LinearLayout android:id="@id/faqRow" style="@style/CardRow"><TextView style="@style/BodyText" android:layout_width="0dp" android:layout_weight="1" android:text="Questions fréquentes" android:textStyle="bold" /><TextView style="@style/MutedText" android:text="›" /></LinearLayout>
            <LinearLayout android:id="@id/contactRow" style="@style/CardRow"><TextView style="@style/BodyText" android:layout_width="0dp" android:layout_weight="1" android:text="Contact support" android:textStyle="bold" /><TextView style="@style/MutedText" android:text="›" /></LinearLayout>
        </LinearLayout>
    </ScrollView>
    <include layout="@layout/include_bottom_nav" />
</LinearLayout>
