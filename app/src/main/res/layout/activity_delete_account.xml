<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@id/screenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    android:orientation="vertical"
    tools:context=".DeleteAccountActivity">

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout style="@style/ScreenBody">
            <TextView android:id="@id/backButton" style="@style/LinkText" android:text="‹ Retour" />
            <TextView style="@style/AppTitle" android:layout_marginTop="16dp" android:text="Supprimer mon compte" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:layout_marginBottom="18dp" android:background="@drawable/bg_card" android:gravity="center" android:orientation="vertical" android:padding="22dp">
                <TextView android:layout_width="64dp" android:layout_height="64dp" android:gravity="center" android:text="!" android:textColor="@color/app_danger" android:textSize="42sp" android:textStyle="bold" />
                <TextView style="@style/BodyText" android:gravity="center" android:text="Êtes-vous sûr de vouloir supprimer votre compte ?" android:textStyle="bold" />
                <TextView style="@style/MutedText" android:layout_marginTop="10dp" android:gravity="center" android:text="Cette action est irréversible. Toutes vos données seront définitivement supprimées." />
            </LinearLayout>
            <EditText style="@style/AppField" android:hint="Entrez SUPPRIMER pour confirmer" />
            <Button android:id="@id/deleteButton" style="@style/AppButtonPrimary" android:background="@drawable/bg_button_danger" android:text="Supprimer mon compte" />
            <Button android:id="@id/cancelButton" style="@style/AppButtonSecondary" android:text="Annuler" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
