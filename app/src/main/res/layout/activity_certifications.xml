<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@id/screenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    android:orientation="vertical"
    tools:context=".CertificationsActivity">

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout style="@style/ScreenBody">
            <TextView android:id="@id/backButton" style="@style/LinkText" android:text="‹ Retour" />
            <TextView style="@style/AppTitle" android:layout_marginTop="16dp" android:text="Certifications" />
            <TextView style="@style/AppSubtitle" android:text="Ajoutez vos certifications professionnelles." />

            <TextView style="@style/CardRow" android:layout_marginTop="20dp" android:text="Certification Cegos&#10;Management RH&#10;2022" android:textColor="@color/app_ink" android:textStyle="bold" />
            <TextView style="@style/CardRow" android:text="Certification Scrum&#10;Scrum Master&#10;2021" android:textColor="@color/app_ink" android:textStyle="bold" />
            <TextView style="@style/CardRow" android:text="Formation LinkedIn&#10;People Analytics&#10;2020" android:textColor="@color/app_ink" android:textStyle="bold" />

            <TextView style="@style/LinkText" android:layout_gravity="center_horizontal" android:layout_marginTop="8dp" android:text="+ Ajouter une certification" />
            <include layout="@layout/include_form_actions" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
