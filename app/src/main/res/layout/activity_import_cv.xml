<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@id/screenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    android:orientation="vertical"
    tools:context=".ImportCvActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout style="@style/ScreenBody">
            <TextView
                android:id="@id/backButton"
                style="@style/LinkText"
                android:text="‹ Retour" />

            <TextView
                style="@style/AppTitle"
                android:layout_marginTop="16dp"
                android:text="Importer un CV" />

            <TextView
                style="@style/AppSubtitle"
                android:text="Gagnez du temps en important votre ancien CV." />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="230dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LinkText"
                    android:text="Cloud" />

                <TextView
                    style="@style/BodyText"
                    android:layout_marginTop="12dp"
                    android:text="Déposez votre fichier ici"
                    android:textStyle="bold" />

                <TextView
                    style="@style/MutedText"
                    android:layout_marginTop="8dp"
                    android:text="ou" />

                <Button
                    style="@style/AppButtonSecondary"
                    android:layout_width="140dp"
                    android:layout_marginTop="8dp"
                    android:text="Parcourir" />
            </LinearLayout>

            <TextView
                style="@style/MutedText"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="Formats acceptés : PDF, DOCX, TXT&#10;Taille max : 10 Mo" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/include_bottom_nav" />
</LinearLayout>
