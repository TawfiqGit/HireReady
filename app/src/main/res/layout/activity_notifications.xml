<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@id/screenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    android:orientation="vertical"
    tools:context=".NotificationsActivity">

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout style="@style/ScreenBody">
            <TextView android:id="@id/backButton" style="@style/LinkText" android:text="‹ Retour" />
            <TextView style="@style/AppTitle" android:layout_marginTop="16dp" android:text="Notifications" />

            <LinearLayout style="@style/CardRow" android:layout_marginTop="22dp"><TextView style="@style/BodyText" android:layout_width="0dp" android:layout_weight="1" android:text="Nouveautés et conseils" android:textStyle="bold" /><Switch android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" /></LinearLayout>
            <LinearLayout style="@style/CardRow"><TextView style="@style/BodyText" android:layout_width="0dp" android:layout_weight="1" android:text="Rappels et suivis" android:textStyle="bold" /><Switch android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" /></LinearLayout>
            <LinearLayout style="@style/CardRow"><TextView style="@style/BodyText" android:layout_width="0dp" android:layout_weight="1" android:text="Offres et promotions" android:textStyle="bold" /><Switch android:layout_width="wrap_content" android:layout_height="wrap_content" /></LinearLayout>
            <LinearLayout style="@style/CardRow"><TextView style="@style/BodyText" android:layout_width="0dp" android:layout_weight="1" android:text="Mises à jour produit&#10;Recevez les dernières mises à jour" android:textStyle="bold" /><Switch android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" /></LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
