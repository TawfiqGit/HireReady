<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@id/screenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    android:orientation="vertical"
    tools:context=".PersonalInfoActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout style="@style/ScreenBody">
            <TextView android:id="@id/backButton" style="@style/LinkText" android:text="‹ Retour" />
            <TextView style="@style/AppTitle" android:layout_marginTop="16dp" android:text="Informations personnelles" />
            <TextView style="@style/AppSubtitle" android:text="Commencez avec les bases de votre CV." />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="18dp">
                <TextView
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:background="@drawable/bg_avatar"
                    android:gravity="center"
                    android:text="CL"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <Button
                    style="@style/AppButtonSecondary"
                    android:layout_width="190dp"
                    android:layout_marginTop="12dp"
                    android:text="Remplacer la photo" />
            </LinearLayout>

            <TextView style="@style/LabelText" android:text="Prénom *" />
            <EditText style="@style/AppField" android:text="Camille" />
            <TextView style="@style/LabelText" android:text="Nom *" />
            <EditText style="@style/AppField" android:text="Laurent" />
            <TextView style="@style/LabelText" android:text="Titre du poste *" />
            <EditText style="@style/AppField" android:text="Responsable des Ressources Humaines" />

            <LinearLayout style="@style/CardRow">
                <TextView style="@style/BodyText" android:layout_width="0dp" android:layout_weight="1" android:text="Informations complémentaires" />
                <TextView style="@style/MutedText" android:text="›" />
            </LinearLayout>

            <include layout="@layout/include_form_actions" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
